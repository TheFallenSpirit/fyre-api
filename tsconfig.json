{
	"compilerOptions": {
		"strict": true,
		"target": "ESNext",
		"outDir": "build",
		"module": "NodeNext",
		"rootDir": "src",
		"skipLibCheck": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noUncheckedIndexedAccess": true
	},
	"include": ["src"],
	"exclude": ["build", "node_modules"]
}
